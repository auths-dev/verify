{
  "name": "@auths/verify-action",
  "version": "1.2.0",
  "description": "GitHub Action to verify commit signatures using Auths identity keys",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "test": "jest --config jest.config.js",
    "lint": "eslint src/**/*.ts",
    "package": "npm run build"
  },
  "keywords": [
    "github-actions",
    "auths",
    "commit-verification",
    "ssh-signatures"
  ],
  "author": "auths",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@actions/io": "^1.1.3",
    "@actions/cache": "^3.2.4",
    "@actions/glob": "^0.5.0",
    "@actions/tool-cache": "^2.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  }
}
